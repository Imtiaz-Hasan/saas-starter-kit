APP_NAME="SaaS Starter Kit"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Central database. Tenant databases are created automatically as tenant_<slug>.
DB_CONNECTION=central
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=saas_central
DB_USERNAME=root
DB_PASSWORD=

# Tenant identification strategy: path (default), subdomain or domain.
# "path" works on plain localhost with no DNS setup (e.g. http://localhost/acme/dashboard).
TENANT_IDENTIFICATION=path

# Sessions/cache are pinned to the central connection so they keep working after
# tenancy swaps the default connection inside tenant requests.
SESSION_DRIVER=database
SESSION_CONNECTION=central
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Use "sync" in local dev so tenant provisioning jobs run immediately.
QUEUE_CONNECTION=sync

CACHE_STORE=database
DB_CACHE_CONNECTION=central

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Stripe / Laravel Cashier. Use your own TEST keys from https://dashboard.stripe.com.
# Create products/prices in Stripe and paste their price IDs below. Leave blank to
# run without billing (the billing page still renders; checkout is disabled).
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=
CASHIER_CURRENCY=usd

VITE_APP_NAME="${APP_NAME}"
